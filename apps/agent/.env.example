# Copy to .env.local for local development (`pnpm dev`).

# Direct Anthropic model access (no Vercel AI Gateway). Required.
ANTHROPIC_API_KEY=

# Route auth for the public HTTP endpoint. In production these gate every
# session route via HTTP Basic; locally, loopback requests are admitted by
# localDev() regardless. /eve/v1/health is always public.
ROUTE_AUTH_BASIC_USER=istatym
ROUTE_AUTH_BASIC_PASSWORD=
