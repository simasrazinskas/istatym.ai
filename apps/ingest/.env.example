# Copy to .env for local runs.

# Postgres connection string. Required for every ingest CLI and the DB test.
DATABASE_URL=postgres://istatym:istatym@localhost:55433/istatym

# Optional. Only used by the LLM cleanup pass of `pnpm ingest:classify --llm`.
# The heuristic classifier works standalone without this key.
ANTHROPIC_API_KEY=

# Voyage AI key (Anthropic's recommended embeddings provider). Required by
# `pnpm ingest:embed` (chunk + embed the current articles into the `chunk` table).
VOYAGE_API_KEY=
# Optional model override (default voyage-4-large).
VOYAGE_EMBED_MODEL=voyage-4-large
