# Copy to .env.local for local development.

# Postgres connection string. Required for retrieval; the server runs migrations
# and bootstraps the Darbo kodeksas consolidation on first boot.
DATABASE_URL=postgres://istatym:istatym@localhost:5432/istatym

# Without this key the /api/ask endpoint degrades gracefully and returns only
# the Postgres-retrieved articles (no LLM answer).
ANTHROPIC_API_KEY=

# Voyage AI key (Anthropic's recommended embeddings provider). When set, /api/ask
# uses production hybrid retrieval (pgvector + pg_search BM25 + RRF + Voyage
# rerank); when unset it falls back to the FTS baseline. The app serves either way.
VOYAGE_API_KEY=
# Optional model overrides (defaults shown).
VOYAGE_EMBED_MODEL=voyage-4-large
VOYAGE_RERANK_MODEL=rerank-2.5
