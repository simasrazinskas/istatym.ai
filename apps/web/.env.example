# Copy to .env.local for local development.

# Postgres connection string. Required for retrieval; the server runs migrations
# and bootstraps the Darbo kodeksas consolidation on first boot.
DATABASE_URL=postgres://istatym:istatym@localhost:5432/istatym

# Without this key the /api/ask endpoint degrades gracefully and returns only
# the Postgres-retrieved articles (no LLM answer).
ANTHROPIC_API_KEY=
